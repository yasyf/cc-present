{
  "name": "round-title-persists-history",
  "events": [
    {
      "origin": "agent",
      "type": "doc.replaced",
      "seq": 1,
      "payload": {
        "schemaVersion": 1,
        "type": "doc.replaced",
        "revision": 1,
        "doc": {
          "version": 1,
          "title": "T",
          "blocks": [{ "id": "a1", "type": "approval" }]
        }
      }
    },
    { "origin": "agent", "type": "round.started", "seq": 2, "payload": { "schemaVersion": 1, "type": "round.started", "title": "round two" } },
    {
      "origin": "agent",
      "type": "block.upserted",
      "seq": 3,
      "payload": { "schemaVersion": 1, "type": "block.upserted", "block": { "id": "a1", "type": "approval" } }
    },
    { "origin": "human", "type": "decision.created", "seq": 4, "payload": { "schemaVersion": 1, "type": "decision.created", "blockId": "a1", "verdict": "approved" } },
    { "origin": "human", "type": "submit", "seq": 5, "payload": { "schemaVersion": 1, "type": "submit", "revision": 1 } }
  ],
  "expected": {
    "schemaVersion": 1,
    "doc": {
      "version": 1,
      "title": "T",
      "blocks": [{ "id": "a1", "type": "approval" }]
    },
    "interactions": {
      "decisions": { "a1": { "verdict": "approved" } },
      "submitted": { "value": true, "revision": 1 }
    },
    "rounds": {
      "current": 3,
      "blockRounds": { "a1": 2 },
      "history": [
        {
          "number": 1,
          "blocks": [{ "id": "a1", "type": "approval" }],
          "decisions": {},
          "choices": {},
          "inputs": {},
          "feedback": {}
        },
        {
          "number": 2,
          "title": "round two",
          "blocks": [{ "id": "a1", "type": "approval" }],
          "decisions": { "a1": { "verdict": "approved" } },
          "choices": {},
          "inputs": {},
          "feedback": {},
          "submittedRevision": 1
        }
      ]
    }
  }
}
