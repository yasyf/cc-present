# GENERATED by cc-guides from .claude/fragments/.gitignore/ — do not edit; edit the fragments and run 'cc-guides render'.
# OS / editor
.DS_Store
*.swp
.idea/
.vscode/

# Local environment
.env*

# Claude Code
.context/
.claude-scratch/
.scratch/
.claude/worktrees/
.claude/settings.local.json

# Python bytecode (guard hooks are Python even in non-Python repos)
__pycache__/
*.py[cod]

# Cargo build output — any target dir variant, anywhere (Rust cores appear in
# repos of every stack; a stray CARGO_TARGET_DIR must never reach the index)
target/
target-cargo/
.cargo-target/

# Go build output
/bin/
/dist/

# Test / coverage
*.test
*.out
coverage.txt

# go-task cache
.task/

# bootstrap verify binary smoke test
.go-smoke/

# Xcode
DerivedData/
build/
*.xcuserstate
xcuserdata/
*.xcworkspace/xcuserdata/

# SwiftPM
.build/
.swiftpm/

# XcodeBuildMCP (local session state: machine-specific device/simulator IDs)
.xcodebuildmcp/

# Web (npm/bun)
web/node_modules/

# Example pack (bun) — deps, lockfile, and bundle are rebuilt by CI
examples/packs/example/node_modules/
examples/packs/example/dist/
examples/packs/example/bun.lock

# Embedded SPA build output — rebuilt by the web build; keep only .gitkeep so
# //go:embed all:dist compiles in a clean tree.
internal/web/dist/*
!internal/web/dist/.gitkeep

# Plugin binary + installer log (installer-managed)
plugin/bin/
plugin/install-binary.log
