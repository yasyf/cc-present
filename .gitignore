# OS / editor
.DS_Store
*.swp
.idea/
.vscode/

# Local environment
.env*

# Claude Code
.context/
.claude/settings.local.json

# Python bytecode (guard hooks are Python even in non-Python repos)
__pycache__/
*.py[cod]

# Go build output
/bin/
/dist/

# Test / coverage
*.test
*.out
coverage.txt

# go-task cache
.task/

# Web (npm/bun)
web/node_modules/

# Example pack (bun) — deps, lockfile, and bundle are rebuilt by CI
examples/packs/example/node_modules/
examples/packs/example/dist/
examples/packs/example/bun.lock

# Embedded SPA build output — rebuilt by the web build; keep only the committed
# placeholder so a clean tree compiles with no web toolchain.
internal/web/dist/*
!internal/web/dist/index.html

# bootstrap verify binary smoke test
.go-smoke/
plugin/bin/
plugin/install-binary.log

# iOS / Xcode
xcuserdata/
ios/CcPresentKit/.build/
DerivedData/
.xcodebuildmcp/
